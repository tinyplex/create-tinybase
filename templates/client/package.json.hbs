{
"name": "{{projectName}}{{#if server}}-client{{/if}}",
"version": "1.0.0",
"scripts": {
{{#list}}
  {{includeFile template="client/index.html.hbs" output="client/index.html"}}
  "dev": "vite"
  {{#if typescript}}
    {{#if svelte}}
      "build": "svelte-check --tsconfig ./tsconfig.json && vite build"
      "check": "svelte-check --tsconfig ./tsconfig.json"
    {{else}}
      "build": "tsc && vite build"
    {{/if}}
  {{else}}
    "build": "vite build"
  {{/if}}
  "preview": "vite preview"
  {{#if prettier}}
    "format": "prettier --write ."
    "format:check": "prettier --check ."
  {{/if}}
  {{#if eslint}}
    "lint": "eslint ."
  {{/if}}
{{/list}}
},
"devDependencies": {
{{#list}}
  "vite": "^8.0.3"
  {{#if typescript}}
    "typescript": "^6.0.2"
    "@types/node": "^25.5.0"
    {{#if svelte}}
      "@tsconfig/svelte": "^5.0.8"
      "svelte-check": "^4.4.6"
    {{/if}}
    {{#if react}}
      "@types/react": "^19.2.14"
      "@types/react-dom": "^19.2.3"
    {{/if}}
  {{/if}}
  {{#if react}}
    "@vitejs/plugin-react": "^6.0.1"
  {{/if}}
  {{#if svelte}}
    "@sveltejs/vite-plugin-svelte": "^7.0.0"
    "svelte": "^5.55.1"
  {{/if}}
  {{#if persistPglite}}
    "vite-plugin-static-copy": "^4.0.0"
  {{/if}}
  {{#if prettier}}
    "prettier": "^3.8.1"
  {{/if}}
  {{#if eslint}}
    "eslint": "^9.39.2"
    {{#if typescript}}
      "typescript-eslint": "^8.57.1"
    {{/if}}
    {{#if react}}
      "eslint-plugin-react": "7.37.5"
      "eslint-plugin-react-hooks": "^7.0.1"
    {{/if}}
  {{/if}}
{{/list}}
},
"dependencies": {
{{#list}}
  "tinybase": "{{#if svelte}}beta{{else}}^8.0.2{{/if}}"
  {{#if react}}
    "react": "^19.2.4"
    "react-dom": "^19.2.4"
  {{/if}}
  {{#if sync}}
    "reconnecting-websocket": "^4.4.0"
  {{/if}}
  {{#if persistSqlite}}
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8"
  {{/if}}
  {{#if persistPglite}}
    "@electric-sql/pglite": "^0.3.16"
  {{/if}}
{{/list}}
}
}
{{#if prettier}}
  {{includeFile template="client/.prettierrc.json.hbs" output="client/.prettierrc.json"}}
{{/if}}
{{#if svelte}}
  {{includeFile template="client/.npmrc.hbs" output="client/.npmrc"}}
{{/if}}
{{#if eslint}}
  {{includeFile template="client/eslint.config.js.hbs" output="client/eslint.config.js"}}
{{/if}}
{{#if needsViteConfig}}
  {{includeFile template="client/vite.config.js.hbs" output="client/vite.config.js"}}
{{/if}}
{{#if typescript}}
  {{includeFile template="client/tsconfig.json.hbs" output="client/tsconfig.json"}}
  {{includeFile template="client/vite-env.d.ts.hbs" output="client/src/vite-env.d.ts"}}
{{/if}}