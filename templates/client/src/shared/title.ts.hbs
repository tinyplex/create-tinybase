{{includeFile template="client/src/shared/title.css.hbs" output="client/src/title.css"}}
{{addImport "import './title.css';"}}

export const createTitle = (): HTMLHeadingElement => {
const title = document.createElement('h1');
title.id = 'topBarTitle';

const logo = document.createElement('img');
logo.src = '/favicon.svg';
logo.id = 'topBarLogo';
logo.alt = 'TinyBase';
title.appendChild(logo);

title.append('TinyBase {{#if (eq appType "chat")}}Chat{{else if (eq appType "drawing")}}Drawing{{else if (eq appType "game")}}Game{{else}}Todos{{/if}}');

return title;
};
