{{includeFile template="client/src/shared/topBar.css.hbs" output="client/src/topBar.css"}}
{{includeFile template="client/src/shared/title.ts.hbs" output="client/src/title.{{scriptExt}}"}}
{{includeFile template="client/src/shared/info.ts.hbs" output="client/src/info.{{scriptExt}}"}}
{{addImport "import './topBar.css';"}}
{{addImport "import {createTitle} from './title';"}}
{{addImport "import {createInfo} from './info';"}}

export const createTopBar = (): HTMLDivElement => {
const topBar = document.createElement('div');
topBar.id = 'topBar';

topBar.appendChild(createTitle());
topBar.appendChild(createInfo());

return topBar;
};
