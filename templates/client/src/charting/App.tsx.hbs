{{addImport "import {StrictMode, useState} from 'react';"}}
{{#unless tinyWidgets}}
  {{includeFile template="client/src/shared/Loading.tsx.hbs" output="client/src/Loading.{{ext}}"}}
  {{addImport "import {Loading} from './Loading';"}}
{{/unless}}
{{addImport "import {Provider} from 'tinybase/ui-react';"}}
{{addImport "import {Inspector} from 'tinybase/ui-react-inspector';"}}
{{includeFile template="client/src/charting/charting.css.hbs" output="client/src/charting.css"}}
{{addImport "import './charting.css';"}}
{{includeFile template="client/src/charting/Store.tsx.hbs" output="client/src/Store.{{ext}}"}}
{{addImport "import {Store} from './Store';"}}
{{includeFile template="client/src/charting/DataTable.tsx.hbs" output="client/src/DataTable.{{ext}}"}}
{{addImport "import {DataTable} from './DataTable';"}}
{{includeFile template="client/src/charting/ChartPanel.tsx.hbs" output="client/src/ChartPanel.{{ext}}"}}
{{addImport "import {ChartPanel} from './ChartPanel';"}}

{{#if tinyWidgets}}
  {{addImport "import {App as TinyWidgetsApp, Card, Loading} from 'tinywidgets';"}}
  {{includeFile template="client/src/app.css.ts.hbs" output="client/src/app.css.ts"}}
  {{includeFile template="client/src/shared/Info.tsx.hbs" output="client/src/Info.{{componentExt}}"}}
  {{includeFile template="client/src/shared/Title.tsx.hbs" output="client/src/Title.{{componentExt}}"}}
  {{addImport "import './app.css.ts';"}}
  {{addImport "import {Info} from './Info';"}}
  {{addImport "import {Title} from './Title';"}}
{{else}}
  {{includeFile template="client/src/shared/TopBar.tsx.hbs" output="client/src/TopBar.{{componentExt}}"}}
  {{addImport "import {TopBar} from './TopBar';"}}
{{/if}}

export const App = () =>
{{#if tinyWidgets}}
  <TinyWidgetsApp title={Title} topNavRight={Info} main={Main} />;
{{else}}
  (
  <>
    <TopBar />
    <Main />
  </>
  );
{{/if}}

const Main = () => {
const [loading, setLoading] = useState(true);

return (
<div id="app">
  <StrictMode>
    <Provider>
      <Store onReady={()=> setLoading(false)} />
        {loading ? (
        {{#if tinyWidgets}}
          <div id="loading">
        {{/if}}
        <Loading />{{#if tinyWidgets}}
</div>{{/if}}
) : (
<>
  <div id="chartingApp" {{#if tinyWidgets}} className="chartingAppWithCards" {{/if}}>
    {{#if tinyWidgets}}
      <Card className="chartingCard">
    {{/if}}
    <DataTable />{{#if tinyWidgets}}</Card>{{/if}}
    {{#if tinyWidgets}}
      <Card className="chartingCard">
    {{/if}}
    <ChartPanel />{{#if tinyWidgets}}</Card>{{/if}}
  </div>
  <Inspector />
</>
)}
</Provider>
</StrictMode>
</div>
);
};