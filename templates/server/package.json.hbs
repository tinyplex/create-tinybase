{
"name": "{{projectName}}-server",
"version": "1.0.0",
"type": "module",
"main": "index.ts",
"scripts": {
{{#list}}
  {{includeFile template="server/index.ts.hbs" output="server/index.ts"}}
  {{#if (eq serverType "node")}}
    "dev": "tsx watch index.ts"
    "start": "node index.js"
  {{else}}
    {{includeFile template="server/wrangler.toml.hbs" output="server/wrangler.toml"}}
    {{#if typescript}}
      {{includeFile template="server/tsconfig.json.hbs" output="server/tsconfig.json"}}
    {{/if}}
    "deploy": "wrangler deploy"
    "dev": "wrangler dev"
    "start": "wrangler dev"
  {{/if}}
{{/list}}
},
"dependencies": {
{{#list}}
  "tinybase": "^8.0.0"
  {{#if (eq serverType "node")}}
    "ws": "^8.19.0"
  {{/if}}
{{/list}}
},
"devDependencies": {
{{#list}}
  {{#if (eq serverType "node")}}
    "@types/ws": "^8.18.1"
  {{else}}
    "@cloudflare/workers-types": "^4.20260307.1"
  {{/if}}
  {{#if typescript}}
    "typescript": "^5.9.3"
    {{#if (eq serverType "node")}}
      "tsx": "^4.21.0"
    {{/if}}
  {{/if}}
  {{#if (eq serverType "durable-objects")}}
    "wrangler": "^4.71.0"
  {{/if}}
{{/list}}
}
}
