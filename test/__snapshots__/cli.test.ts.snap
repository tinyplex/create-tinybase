  "client/src/Input.jsx": "import './input.css';

export const Input = ({
  id,
  value,
  onChange,
  placeholder = '',
  autoFocus = false,
}) => (
  <input
    id={id}
    type="text"
    value={value}
    onChange={(e) => onChange(e.target.value)}
    placeholder={placeholder}
    autoFocus={autoFocus}
  />
);
",
  "client/src/Loading.jsx": "import './loading.css';

export const Loading = () => <div id="loading" />;
",
  "client/src/Message.jsx": "import {useRow, STORE_ID} from './ChatStore';
import './message.css';

export const Message = ({rowId}) => {
  const {username, text, timestamp} = useRow('messages', rowId, STORE_ID);

  return (
    <div className="message">
      <span className="username">{username}:</span>
      <span className="text">{text}</span>
      <span className="time">{new Date(timestamp).toLocaleTimeString()}</span>
    </div>
  );
};
",
  "client/src/MessageInput.jsx": "import {useState} from 'react';
import {useAddRowCallback, STORE_ID as CHAT_STORE_ID} from './ChatStore';
import {useValue, STORE_ID as SETTINGS_STORE_ID} from './SettingsStore';
import './messageInput.css';
import {Button} from './Button';
import {Input} from './Input';

export const MessageInput = () => {
  const [message, setMessage] = useState('');
  const username = useValue('username', SETTINGS_STORE_ID) || 'Anonymous';

  const handleSend = useAddRowCallback(
    'messages',
    () => ({
      username,
      text: message.trim(),
      timestamp: Date.now(),
    }),
    [message, username],
    CHAT_STORE_ID,
  );

  const onSubmit = (e) => {
    e.preventDefault();
    if (message.trim()) {
      handleSend();
      setMessage('');
    }
  };

  return (
    <form onSubmit={onSubmit} id="messageInput">
      <Input
        value={message}
        onChange={setMessage}
        placeholder="Type a message..."
        autoFocus
      />
      <Button type="submit" variant="primary">
        Send
      </Button>
    </form>
  );
};
",
  "client/src/Messages.jsx": "import {useSortedRowIds, STORE_ID} from './ChatStore';
import './messages.css';
import {Message} from './Message';

export const Messages = () => {
  const sortedIds = useSortedRowIds(
    'messages',
    'timestamp',
    false,
    0,
    undefined,
    STORE_ID,
  );

  return (
    <div id="messages">
      {sortedIds.map((id) => (
        <Message key={id} rowId={id} />
      ))}
    </div>
  );
};
",
  "client/src/SettingsStore.jsx": "import {
  useCreateStore,
  useProvideStore,
  useValue,
  useValueState,
} from 'tinybase/ui-react';
import {
  DEFAULT_VALUES,
  STORE_ID,
  createSettingsStore,
} from './settingsStoreData';
import {createLocalPersister} from 'tinybase/persisters/persister-browser';
import {useCreatePersister} from 'tinybase/ui-react';

export {STORE_ID};
export {useValue, useValueState};

export const SettingsStore = ({onReady}) => {
  const store = useCreateStore(() => createSettingsStore());

  useProvideStore(STORE_ID, store);

  useCreatePersister(
    store,
    (store) => createLocalPersister(store, STORE_ID),
    [],
    async (persister) => {
      await persister.load([{}, DEFAULT_VALUES]);
      await persister.startAutoSave();
      onReady?.();
    },
  );

  return null;
};
",
  "client/src/TinyBaseApp.jsx": "import {StrictMode, useState} from 'react';
import {Loading} from './Loading';
import {Provider} from 'tinybase/ui-react';
import {Inspector} from 'tinybase/ui-react-inspector';
import {SettingsStore} from './SettingsStore';
import {ChatStore} from './ChatStore';
import {UsernameInput} from './UsernameInput';
import {Messages} from './Messages';
import {MessageInput} from './MessageInput';

export const App = () => {
  const [settingsReady, setSettingsReady] = useState(false);
  const [chatReady, setChatReady] = useState(false);
  const loading = !settingsReady || !chatReady;

  return (
    <StrictMode>
      <Provider>
        <SettingsStore onReady={() => setSettingsReady(true)} />
        <ChatStore onReady={() => setChatReady(true)} />
        {loading ? (
          <Loading />
        ) : (
          <>
            <UsernameInput />
            <Messages />
            <MessageInput />
            <Inspector />
          </>
        )}
      </Provider>
    </StrictMode>
  );
};
",
