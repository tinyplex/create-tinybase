    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;800&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>TinyBase Chat</title>
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        user-select: none;
        margin: 0;
        padding: 0;
      }

      body {
        --hue: 270;
        --fg: oklch(85% 0.01 var(--hue));
        --fg2: oklch(60% 0.01 var(--hue));
        --bg: oklch(20% 0.01 var(--hue));
        --bg2: oklch(25% 0.01 var(--hue));
        --border: oklch(30% 0.01 var(--hue));
        --bg-header: oklch(30% 0.008 var(--hue) / 0.5);
        --accent: #d81b60;
        color: var(--fg);
        background: var(--bg);
        font-family: 'Inter', sans-serif;
      }

      #appContainer {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      #app {
        max-width: 60rem;
        width: 100%;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
    </style>
  </head>

  <body>
    <div id="appContainer">
      <div id="topBarMount"></div>
      <div id="app"></div>
    </div>

    <script type="module" src="/src/index.ts"></script>
  </body>
</html>
