  transform: translateY(0);
}

#infoTooltip {
  position: absolute;
  right: 0;
  top: calc(100% + 0.5rem);
  background: var(--info-bg2);
  border: 1px solid var(--info-border);
  border-radius: 0.375rem;
  padding: 0.75rem 1rem;
  font-size: 0.85rem;
