  "client/src/Board.jsx": "import './board.css';
import {useMemo} from 'react';
import {useValue, STORE_ID} from './Store';
import {Square} from './Square';

export const Board = () => {
  const gameStatus = useValue('gameStatus', STORE_ID);
  const winningLine = useValue('winningLine', STORE_ID);

  const winningPositions = useMemo(() => {
    if (!winningLine || typeof winningLine !== 'string') return new Set();
    return new Set(winningLine.split(','));
  }, [winningLine]);

  const disabled = gameStatus !== 'playing';

  return (
    <div id="board">
      {Array.from({length: 9}, (_, i) => (
        <Square
          key={i}
          position={i.toString()}
          disabled={disabled}
          winning={winningPositions.has(i.toString())}
        />
      ))}
    </div>
  );
};
",
  "client/src/Button.jsx": "import './button.css';
import {ReactNode} from 'react';

export const Button = ({
  children,
  onClick,
  variant = 'default',
  type = 'button',
}) => (
  <button
    onClick={onClick}
    type={type}
    className={variant === 'primary' ? 'primary' : undefined}
  >
    {children}
  </button>
);
",
  "client/src/Game.jsx": "import {useSetValuesCallback, useTableListener, STORE_ID} from './Store';
import {Button} from './Button';
import {Board} from './Board';
import {GameStatus} from './GameStatus';

const WINNING_LINES = [
  ['0', '1', '2'],
  ['3', '4', '5'],
  ['6', '7', '8'],
  ['0', '3', '6'],
  ['1', '4', '7'],
  ['2', '5', '8'],
  ['0', '4', '8'],
  ['2', '4', '6'],
];

export const Game = () => {
  useTableListener(
    'board',
    (store) => {
      const gameStatus = store.getValue('gameStatus');
      if (gameStatus !== 'playing') return;

      for (const line of WINNING_LINES) {
        const [a, b, c] = line;
        const cellA = store.getCell('board', a, 'value');
        const cellB = store.getCell('board', b, 'value');
        const cellC = store.getCell('board', c, 'value');

        if (cellA && cellA === cellB && cellA === cellC) {
          store.setValue('gameStatus', 'won');
          store.setValue('winner', cellA);
          store.setValue('winningLine', line.join(','));
          return;
        }
      }

      if (store.getRowCount('board') === 9) {
        store.setValue('gameStatus', 'draw');
        return;
      }

      const currentPlayer = store.getValue('currentPlayer');
      store.setValue('currentPlayer', currentPlayer === 'X' ? 'O' : 'X');
    },
    [],
    true,
    STORE_ID,
  );

  const resetGame = useSetValuesCallback(
    (_, store) => {
      store.delTable('board');
      return {currentPlayer: 'X', gameStatus: 'playing'};
    },
    [],
    STORE_ID,
  );

  return (
    <>
      <GameStatus />
      <Board />
      <div style={{textAlign: 'center', marginTop: '2rem'}}>
        <Button onClick={resetGame} variant="primary">
          New Game
        </Button>
      </div>
    </>
  );
};
",
  "client/src/GameStatus.jsx": "import './gameStatus.css';
import {useValue, STORE_ID} from './Store';

export const GameStatus = () => {
  const gameStatus = useValue('gameStatus', STORE_ID);
  const currentPlayer = useValue('currentPlayer', STORE_ID);
  const winner = useValue('winner', STORE_ID);

  return (
    <div id="gameStatus">
      {gameStatus === 'playing' && (
        <>
          Player <span className="player">{currentPlayer}</span>&apos;s turn
        </>
      )}
      {gameStatus === 'won' && (
        <>
          Player <span className="winner">{winner}</span> wins!
        </>
      )}
      {gameStatus === 'draw' && <>It&apos;s a draw </>}
    </div>
  );
};
",
