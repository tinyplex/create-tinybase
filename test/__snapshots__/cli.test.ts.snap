        src="/ts.svg"
        className="infoTechIcon"
        title="Written in TypeScript"
      />
      <img src="/react.svg" className="infoTechIcon" title="Built with React" />
    </div>
    <div id="infoIcon">
      i
      <div id="infoTooltip">
