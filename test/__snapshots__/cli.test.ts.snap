  "client/src/App.svelte": "<script lang="ts">
  import {Provider} from 'tinybase/ui-svelte';
  import {Inspector} from 'tinybase/ui-svelte-inspector';
  import ChatStore from './ChatStore.svelte';
  import Loading from './Loading.svelte';
  import MessageInput from './MessageInput.svelte';
  import Messages from './Messages.svelte';
  import SettingsStore from './SettingsStore.svelte';
  import UsernameInput from './UsernameInput.svelte';

  let settingsReady = $state(false);
  let chatReady = $state(false);
  const loading = $derived(!settingsReady || !chatReady);
</script>

<Provider>
  <SettingsStore onReady={() => (settingsReady = true)} />
  <ChatStore onReady={() => (chatReady = true)} />
  {#if loading}
    <Loading />
  {:else}
    <UsernameInput />
    <Messages />
    <MessageInput />
    <Inspector />
  {/if}
</Provider>
",
  "client/src/Button.svelte": "<script lang="ts">
  import './button.css';
  import type {Snippet} from 'svelte';

  let {
    children,
    onclick = undefined,
    type = 'button',
    variant = 'default',
  }: {
    children?: Snippet;
    onclick?: () => void;
    type?: 'button' | 'submit' | 'reset';
    variant?: 'default' | 'primary';
  } = $props();
</script>

<button {type} class:primary={variant === 'primary'} {onclick}>
  {@render children?.()}
</button>
",
  "client/src/ChatStore.svelte": "<script lang="ts">
  import {provideStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {createLocalPersister} from 'tinybase/persisters/persister-browser';
  import {STORE_ID, createChatStore} from './chatStore';

  let {onReady}: {onReady?: () => void} = $props();

  const store = createChatStore();

  provideStore(STORE_ID, store);

  onMount(async () => {
    const persister = createLocalPersister(store, STORE_ID);
    await persister.load();
    await persister.startAutoSave();
    onReady?.();
  });
</script>
",
  "client/src/Info.svelte": "<script lang="ts">
