  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: center;
  margin: 0 auto 1rem;
  padding: 0.75rem;
  border: 1px solid var(--border);
  border-radius: 0.375rem;
  justify-content: space-between;
  max-width: 600px;
}
