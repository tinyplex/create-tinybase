import {createLocalPersister} from 'tinybase/persisters/persister-browser';

export const STORE_ID = 'settings';

export const DEFAULT_VALUES = {username: getRandomName()};

export const createSettingsStore = () => createStore();

export const settingsStore = createSettingsStore();

let resolveSettingsReady;
export const settingsStoreReady = new Promise((resolve) => {
  resolveSettingsReady = resolve;
});

const settingsPersister = createLocalPersister(settingsStore, STORE_ID);
settingsPersister.load([{}, DEFAULT_VALUES]).then(() => {
  settingsPersister.startAutoSave();
  resolveSettingsReady();
});
