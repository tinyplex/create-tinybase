  "client/src/messageInput.ts": "import './messageInput.css';
import {type SettingsStore} from './settingsStore';
import {type ChatStore} from './chatStore';
import {createButton} from './button';
import {createInput} from './input';

export const createMessageInput = (
  settingsStore: SettingsStore,
  chatStore: ChatStore,
): HTMLFormElement => {
  const messageInputContainer = document.createElement('form');
  messageInputContainer.id = 'messageInput';

  const messageInput = createInput('Type a message...');
  messageInputContainer.appendChild(messageInput);

  const sendMessage = () => {
    const text = messageInput.value.trim();
    if (text) {
      chatStore.addRow('messages', {
        username: settingsStore.getValue('username') || 'Anonymous',
        text,
        timestamp: Date.now(),
      });
      messageInput.value = '';
      messageInput.focus();
    }
  };

  messageInputContainer.addEventListener('submit', (event) => {
    event.preventDefault();
    sendMessage();
  });

  const sendButton = createButton('Send', null, 'primary', 'submit');
  messageInputContainer.appendChild(sendButton);

  return messageInputContainer;
};
",
  "client/src/messages.css": "#messages {
  overflow-y: auto;
  padding: 1rem 0;
  height: 400px;
  margin-bottom: 1rem;
