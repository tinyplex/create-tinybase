  "client/src/App.svelte": "<script lang="ts">
  import {Provider} from 'tinybase/ui-svelte';
  import {Inspector} from 'tinybase/ui-svelte-inspector';
  import ChatStore from './ChatStore.svelte';
  import Loading from './Loading.svelte';
  import MessageInput from './MessageInput.svelte';
  import Messages from './Messages.svelte';
  import SettingsStore from './SettingsStore.svelte';
  import UsernameInput from './UsernameInput.svelte';

  let settingsReady = $state(false);
  let chatReady = $state(false);
  const loading = $derived(!settingsReady || !chatReady);
</script>

<Provider>
  <SettingsStore onReady={() => (settingsReady = true)} />
  <ChatStore onReady={() => (chatReady = true)} />
  {#if loading}
    <Loading />
  {:else}
    <UsernameInput />
    <Messages />
    <MessageInput />
    <Inspector />
  {/if}
</Provider>
",
  "client/src/Button.svelte": "<script lang="ts">
  import './button.css';
  import type {Snippet} from 'svelte';

  let {
    children,
    onclick = undefined,
    type = 'button',
    variant = 'default',
  }: {
    children?: Snippet;
    onclick?: () => void;
    type?: 'button' | 'submit' | 'reset';
    variant?: 'default' | 'primary';
  } = $props();
</script>

<button {type} class:primary={variant === 'primary'} {onclick}>
  {@render children?.()}
</button>
",
  "client/src/ChatStore.svelte": "<script lang="ts">
  import {provideStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {createSqliteWasmPersister} from 'tinybase/persisters/persister-sqlite-wasm';
  import {getDb} from './sqlite';
  import {STORE_ID, createChatStore} from './chatStore';

  let {onReady}: {onReady?: () => void} = $props();

  const store = createChatStore();

  provideStore(STORE_ID, store);

  onMount(async () => {
    const {sqlite3, db} = await getDb();
    const persister = createSqliteWasmPersister(store, sqlite3, db, STORE_ID);
    await persister.load();
    await persister.startAutoSave();
    onReady?.();
  });
</script>
",
  "client/src/Info.svelte": "<script lang="ts">
  import './info.css';
</script>

<div id="info">
  <div id="infoTech">
    <img src="/ts.svg" class="infoTechIcon" title="Written in TypeScript" />
    <img src="/svelte.svg" class="infoTechIcon" title="Built with Svelte" />
    <img
      src="/sqlite.svg"
      class="infoTechIcon"
      title="Persists data to SQLite"
    />
  </div>
  <div id="infoIcon">
    i
    <div id="infoTooltip">
      A real-time chat application demonstrating TinyBase's reactive data
      management.
    </div>
  </div>
</div>
",
  "client/src/Input.svelte": "<script lang="ts">
  import './input.css';
  import {onMount} from 'svelte';

  let {
    id = undefined,
    value = '',
    onChange = undefined,
    placeholder = '',
    autoFocus = false,
  }: {
    id?: string;
    value?: string;
    onChange?: (value: string) => void;
    placeholder?: string;
    autoFocus?: boolean;
  } = $props();

  let input: HTMLInputElement | undefined;

  const handleInput = (event: Event) => {
    const input = event.currentTarget as HTMLInputElement;
    onChange?.(input.value);
  };

  onMount(() => {
    if (autoFocus) {
      input?.focus();
    }
  });
</script>

<input
  bind:this={input}
  {id}
  type="text"
  {value}
  oninput={handleInput}
  {placeholder}
/>
",
  "client/src/Loading.svelte": "<script>
  import './loading.css';
</script>

<div id="loading"></div>
",
  "client/src/Message.svelte": "<script lang="ts">
  import './message.css';
  import {getRow} from 'tinybase/ui-svelte';
  import {STORE_ID} from './chatStore';
  import type {MessageRow} from './chatStore';

  let {rowId}: {rowId: string} = $props();

  const message = getRow('messages', () => rowId, STORE_ID) as {
    readonly current: MessageRow;
  };

  const getTime = (timestamp: number) =>
    new Date(timestamp).toLocaleTimeString();
</script>

<div class="message">
  <span class="username">{message.current.username}:</span>
  <span class="text">{message.current.text}</span>
  <span class="time">{getTime(message.current.timestamp)}</span>
</div>
",
  "client/src/MessageInput.svelte": "<script lang="ts">
  import './input.css';
  import './messageInput.css';
  import Button from './Button.svelte';
  import {getValue, getStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {STORE_ID as CHAT_STORE_ID} from './chatStore';
  import {STORE_ID as SETTINGS_STORE_ID} from './settingsStore';
  import type {Store} from 'tinybase';

  let message = $state('');
  let input: HTMLInputElement | undefined;

  const chatStore = getStore(CHAT_STORE_ID) as Store;

  const username = getValue('username', SETTINGS_STORE_ID) as {
    current: string | undefined;
  };

  const sendMessage = () => {
    const text = message.trim();
    if (!text) {
      return;
    }

    chatStore.addRow('messages', {
      username: username.current || 'Anonymous',
      text,
      timestamp: Date.now(),
    });

    message = '';
    input?.focus();
  };

  const handleSubmit = (event: SubmitEvent) => {
    event.preventDefault();
    sendMessage();
  };

  onMount(() => {
    input?.focus();
  });
</script>

<form id="messageInput" onsubmit={handleSubmit}>
  <input
    bind:this={input}
    bind:value={message}
    type="text"
    placeholder="Type a message..."
  />
  <Button variant="primary" type="submit">Send</Button>
</form>
",
  "client/src/Messages.svelte": "<script lang="ts">
  import './messages.css';
  import {getSortedRowIds} from 'tinybase/ui-svelte';
  import Message from './Message.svelte';
  import {STORE_ID} from './chatStore';

  const messageIds = getSortedRowIds(
    'messages',
    'timestamp',
    false,
    0,
    undefined,
    STORE_ID,
  ) as {readonly current: string[]};
</script>

<div id="messages">
  {#each messageIds.current as rowId (rowId)}
    <Message {rowId} />
  {/each}
</div>
",
  "client/src/SettingsStore.svelte": "<script lang="ts">
  import {provideStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {createSqliteWasmPersister} from 'tinybase/persisters/persister-sqlite-wasm';
  import {getDb} from './sqlite';
  import {DEFAULT_VALUES, STORE_ID, createSettingsStore} from './settingsStore';

  let {onReady}: {onReady?: () => void} = $props();

  const store = createSettingsStore();

  provideStore(STORE_ID, store);

  onMount(async () => {
    const {sqlite3, db} = await getDb();
    const persister = createSqliteWasmPersister(store, sqlite3, db, STORE_ID);
    await persister.load([{}, DEFAULT_VALUES]);
    await persister.startAutoSave();
    onReady?.();
  });
</script>
",
  "client/src/Title.svelte": "<script lang="ts">
  import './title.css';
</script>

<h1 id="topBarTitle">
  <img src="/favicon.svg" id="topBarLogo" alt="TinyBase" />
  TinyBase Chat
</h1>
",
  "client/src/TopBar.svelte": "<script lang="ts">
  import './topBar.css';
  import Title from './Title.svelte';
  import Info from './Info.svelte';
</script>

<div id="topBar">
  <Title />
  <Info />
</div>
",
  "client/src/UsernameInput.svelte": "<script lang="ts">
  import './usernameInput.css';
  import Input from './Input.svelte';
  import {getValue} from 'tinybase/ui-svelte';
  import {STORE_ID} from './settingsStore';

  const username = getValue('username', STORE_ID) as {
    current: string | undefined;
  };
</script>

<div id="usernameInput">
  <label for="usernameInputField">Your name:</label>
  <Input
    id="usernameInputField"
    value={username.current ?? ''}
    onChange={(value) => {
      username.current = value;
    }}
    placeholder="Enter your name"
  />
</div>
",
  "client/src/button.css": "button {
  padding: 0.5rem 1rem;
  border: 1px solid #666;
  border-radius: 0.25rem;
  background: #222;
  color: #fff;
  font-family: inherit;
  font-weight: 800;
  cursor: pointer;
  margin: 0.5rem;
}

button:hover {
  border-color: #d81b60;
}

button.primary {
  background: #d81b60;
  border: none;
  padding: 0.75rem 1.5rem;
}

button.primary:hover {
  background: #c2185b;
}
",
  "client/src/chatStore.ts": "import {createMergeableStore} from 'tinybase';
import {getDefaultContent} from './utils';

export const STORE_ID = 'chat';

export type MessageRow = {username: string; text: string; timestamp: number};

export const createChatStore = () =>
  createMergeableStore().setDefaultContent(getDefaultContent());
",
  "client/src/index.ts": "import {mount} from 'svelte';
import App from './App.svelte';
import TopBar from './TopBar.svelte';

addEventListener('load', () => {
  mount(TopBar, {
    target: document.getElementById('topBarMount')!,
  });
  mount(App, {
    target: document.getElementById('app')!,
  });
});
",
  "client/src/info.css": "#info {
  --info-fg: var(--fg, oklch(85% 0.01 270));
  --info-fg2: var(--fg2, oklch(60% 0.01 270));
  --info-bg2: var(--bg2, oklch(25% 0.01 270));
  --info-border: var(--border, oklch(30% 0.01 270));
  --info-accent: var(--accent, #d81b60);
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

#infoTech {
  display: flex;
  align-items: center;
  gap: 0.375rem;
}

.infoTechIcon {
  width: 1.25rem;
  height: 1.25rem;
  display: block;
  flex-shrink: 0;
}

#infoIcon {
  width: 1.25rem;
  height: 1.25rem;
  border: 2px solid var(--info-fg2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 800;
  color: var(--info-fg2);
  cursor: help;
  transition: all 0.2s;
  user-select: none;
}

#infoIcon:hover {
  border-color: var(--info-accent);
  color: var(--info-accent);
}

#infoIcon:hover #infoTooltip {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

#infoTooltip {
  position: absolute;
  right: 0;
  top: calc(100% + 0.5rem);
  background: var(--info-bg2);
  border: 1px solid var(--info-border);
  border-radius: 0.375rem;
  padding: 0.75rem 1rem;
  font-size: 0.85rem;
  font-weight: 400;
  width: 20rem;
  white-space: normal;
  color: var(--info-fg);
  line-height: 1.5;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-0.25rem);
  transition: all 0.2s;
  pointer-events: none;
  box-shadow: 0 1px 2px 0 #0007;
  z-index: 1;
}

#infoTooltip a {
  color: var(--info-fg);
  text-decoration: underline;
}

#infoTooltip::before {
  content: '';
  position: absolute;
  right: 0.75rem;
  top: -0.375rem;
  width: 0.75rem;
  height: 0.75rem;
  background: var(--info-bg2);
  border-left: 1px solid var(--info-border);
  border-top: 1px solid var(--info-border);
  transform: rotate(45deg);
}
",
  "client/src/input.css": "input[type='text'] {
  padding: 0.5rem 0.75rem;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 0.375rem;
  color: var(--fg);
  font-family: inherit;
  font-size: 1rem;
  line-height: 1.5;
