        --bg2: oklch(25% 0.01 var(--hue));
        --border: oklch(30% 0.01 var(--hue));
        --bg-header: oklch(30% 0.008 var(--hue) / 0.5);
        --accent: #d81b60;
        color: var(--fg);
        background: var(--bg);
        font-family: 'Inter', sans-serif;
      }

      #appContainer {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      #app {
        max-width: 60rem;
        width: 100%;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
    </style>
  </head>

  <body>
