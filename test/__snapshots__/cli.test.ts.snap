.infoTechIcon {
  width: 1.25rem;
  height: 1.25rem;
  display: block;
  flex-shrink: 0;
}

#infoIcon {
  width: 1.25rem;
  height: 1.25rem;
  border: 2px solid var(--info-fg2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 800;
  color: var(--info-fg2);
  cursor: help;
  transition: all 0.2s;
  user-select: none;
}

#infoIcon:hover {
  border-color: var(--info-accent);
  color: var(--info-accent);
}

#infoIcon:hover #infoTooltip {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

#infoTooltip {
  position: absolute;
  right: 0;
  top: calc(100% + 0.5rem);
  background: var(--info-bg2);
  border: 1px solid var(--info-border);
  border-radius: 0.375rem;
  padding: 0.75rem 1rem;
  font-size: 0.85rem;
  font-weight: 400;
  width: 20rem;
  white-space: normal;
  color: var(--info-fg);
  line-height: 1.5;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-0.25rem);
  transition: all 0.2s;
  pointer-events: none;
  box-shadow: 0 1px 2px 0 #0007;
  z-index: 1;
}

#infoTooltip a {
  color: var(--info-fg);
  text-decoration: underline;
}

#infoTooltip::before {
  content: '';
  position: absolute;
  right: 0.75rem;
  top: -0.375rem;
  width: 0.75rem;
  height: 0.75rem;
  background: var(--info-bg2);
  border-left: 1px solid var(--info-border);
  border-top: 1px solid var(--info-border);
  transform: rotate(45deg);
}
",
