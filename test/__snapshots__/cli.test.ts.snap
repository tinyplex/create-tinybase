export const Info = () => (
  <div id="info">
    <div id="infoTech">
      <img
        src="/js.svg"
        className="infoTechIcon"
        title="Written in JavaScript"
      />
      <img src="/react.svg" className="infoTechIcon" title="Built with React" />
    </div>
    <div id="infoIcon">
      i
      <div id="infoTooltip">
        {
          'A tic-tac-toe game demonstrating turn-based logic and computed game state using TinyBase.'
        }
      </div>
    </div>
  </div>
);
