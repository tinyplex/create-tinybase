        background: var(--bg);
        font-family: 'Inter', sans-serif;
      }

      #appContainer {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      #app {
        max-width: 60rem;
        width: 100%;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
    </style>
  </head>

  <body>
    <div id="appContainer">
      <div id="topBarMount"></div>
      <div id="app"></div>
    </div>

    <script type="module" src="/src/index.js"></script>
  </body>
</html>
