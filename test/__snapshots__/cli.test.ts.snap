  "client/src/square.ts": "import './square.css';

export const createSquare = (
  value: string | undefined,
  onClick: () => void,
  disabled: boolean,
  winning: boolean,
): HTMLButtonElement => {
  const square = document.createElement('button');
  square.className = \`square\${disabled ? ' disabled' : ''}\${winning ? ' winning' : ''}\`;
  square.textContent = value ?? '';
  square.disabled = disabled;
  square.addEventListener('click', onClick);
  return square;
};
",
  "client/src/store.ts": "import {createMergeableStore} from 'tinybase';
import {createPglitePersister} from 'tinybase/persisters/persister-pglite';
import {getPgLite} from './pglite';

export const STORE_ID = 'game';

export const createGameStore = () =>
  createMergeableStore().setDefaultContent([
    {},
    {
      currentPlayer: 'X',
      gameStatus: 'playing',
    },
  ]);

export const store = createGameStore();

let resolveReady: () => void;
export const storeReady = new Promise<void>((resolve) => {
  resolveReady = resolve;
});

getPgLite().then((pgLite) => {
  createPglitePersister(store, pgLite, STORE_ID).then((persister) => {
    persister.load().then(() => {
      persister.startAutoSave();
      resolveReady();
    });
  });
});

export type GameStore = typeof store;
