    <img src="/svelte.svg" class="infoTechIcon" title="Built with Svelte" />
  </div>
  <div id="infoIcon">
    i
    <div id="infoTooltip">
      A real-time chat application demonstrating TinyBase's reactive data
      management.
    </div>
