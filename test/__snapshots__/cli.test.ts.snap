  "client/src/Input.jsx": "import './input.css';

export const Input = ({
  id,
  value,
  onChange,
  placeholder = '',
  autoFocus = false,
}) => (
  <input
    id={id}
    type="text"
    value={value}
    onChange={(e) => onChange(e.target.value)}
