button.primary {
  background: #d81b60;
  border: none;
  padding: 0.75rem 1.5rem;
}

button.primary:hover {
  background: #c2185b;
}
",
  "client/src/chatStore.ts": "import {createMergeableStore} from 'tinybase';
import {getDefaultContent} from './utils';

export const STORE_ID = 'chat';

export type MessageRow = {username: string; text: string; timestamp: number};

export const createChatStore = () =>
  createMergeableStore().setDefaultContent(getDefaultContent());
",
  "client/src/index.ts": "import {mount} from 'svelte';
import App from './App.svelte';
import TopBar from './TopBar.svelte';

addEventListener('load', () => {
  mount(TopBar, {
    target: document.getElementById('topBarMount')!,
  });
  mount(App, {
    target: document.getElementById('app')!,
  });
});
",
  "client/src/info.css": "#info {
  --info-fg: var(--fg, oklch(85% 0.01 270));
  --info-fg2: var(--fg2, oklch(60% 0.01 270));
  --info-bg2: var(--bg2, oklch(25% 0.01 270));
