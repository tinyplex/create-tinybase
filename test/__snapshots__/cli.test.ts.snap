  "client/src/sqlite.jsx": "import sqlite3InitModule from '@sqlite.org/sqlite-wasm';

let sqlite3Promise = null;
let db = null;
const initSqlite = sqlite3InitModule;

export const getDb = async () => {
  if (!sqlite3Promise) {
    sqlite3Promise = initSqlite();
  }
  if (!db) {
    const sqlite3 = await sqlite3Promise;
    db = new sqlite3.oo1.DB('file:local?vfs=kvvfs', 'c');
  }
  return {sqlite3: await sqlite3Promise, db};
};
