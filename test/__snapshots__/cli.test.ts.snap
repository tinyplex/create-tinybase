</div>
",
  "client/src/Input.svelte": "<script lang="ts">
  import './input.css';
  import {onMount} from 'svelte';

  let {
    id = undefined,
    value = '',
    onChange = undefined,
    placeholder = '',
    autoFocus = false,
  }: {
    id?: string;
    value?: string;
    onChange?: (value: string) => void;
    placeholder?: string;
    autoFocus?: boolean;
  } = $props();

  let input: HTMLInputElement | undefined;

  const handleInput = (event: Event) => {
    const input = event.currentTarget as HTMLInputElement;
    onChange?.(input.value);
  };

  onMount(() => {
    if (autoFocus) {
      input?.focus();
    }
  });
</script>

<input
  bind:this={input}
  {id}
  type="text"
  {value}
  oninput={handleInput}
  {placeholder}
/>
",
  "client/src/Loading.svelte": "<script>
  import './loading.css';
</script>

<div id="loading"></div>
",
  "client/src/Message.svelte": "<script lang="ts">
  import './message.css';
  import {getRow} from 'tinybase/ui-svelte';
  import {STORE_ID} from './chatStore';
  import type {MessageRow} from './chatStore';

  let {rowId}: {rowId: string} = $props();

  const message = getRow('messages', () => rowId, STORE_ID) as {
    readonly current: MessageRow;
  };

  const getTime = (timestamp: number) =>
    new Date(timestamp).toLocaleTimeString();
</script>

<div class="message">
  <span class="username">{message.current.username}:</span>
  <span class="text">{message.current.text}</span>
  <span class="time">{getTime(message.current.timestamp)}</span>
</div>
",
  "client/src/MessageInput.svelte": "<script lang="ts">
  import './input.css';
  import './messageInput.css';
  import Button from './Button.svelte';
  import {getValue, getStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {STORE_ID as CHAT_STORE_ID} from './chatStore';
  import {STORE_ID as SETTINGS_STORE_ID} from './settingsStore';
  import type {Store} from 'tinybase';

  let message = $state('');
  let input: HTMLInputElement | undefined;

  const chatStore = getStore(CHAT_STORE_ID) as Store;

  const username = getValue('username', SETTINGS_STORE_ID) as {
    current: string | undefined;
  };

  const sendMessage = () => {
    const text = message.trim();
    if (!text) {
      return;
    }

    chatStore.addRow('messages', {
      username: username.current || 'Anonymous',
      text,
      timestamp: Date.now(),
    });

    message = '';
    input?.focus();
  };

  const handleSubmit = (event: SubmitEvent) => {
    event.preventDefault();
    sendMessage();
  };

  onMount(() => {
    input?.focus();
  });
</script>

<form id="messageInput" onsubmit={handleSubmit}>
  <input
    bind:this={input}
    bind:value={message}
    type="text"
    placeholder="Type a message..."
  />
  <Button variant="primary" type="submit">Send</Button>
</form>
",
  "client/src/Messages.svelte": "<script lang="ts">
  import './messages.css';
  import {getSortedRowIds} from 'tinybase/ui-svelte';
  import Message from './Message.svelte';
  import {STORE_ID} from './chatStore';

  const messageIds = getSortedRowIds(
    'messages',
    'timestamp',
    false,
    0,
    undefined,
    STORE_ID,
  ) as {readonly current: string[]};
</script>

<div id="messages">
  {#each messageIds.current as rowId (rowId)}
    <Message {rowId} />
  {/each}
</div>
",
  "client/src/SettingsStore.svelte": "<script lang="ts">
  import {provideStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {createLocalPersister} from 'tinybase/persisters/persister-browser';
  import {DEFAULT_VALUES, STORE_ID, createSettingsStore} from './settingsStore';

  let {onReady}: {onReady?: () => void} = $props();

  const store = createSettingsStore();

  provideStore(STORE_ID, store);

  onMount(async () => {
    const persister = createLocalPersister(store, STORE_ID);
    await persister.load([{}, DEFAULT_VALUES]);
    await persister.startAutoSave();
    onReady?.();
  });
</script>
",
  "client/src/Title.svelte": "<script lang="ts">
  import './title.css';
</script>

<h1 id="topBarTitle">
  <img src="/favicon.svg" id="topBarLogo" alt="TinyBase" />
  TinyBase Chat
</h1>
",
  "client/src/TopBar.svelte": "<script lang="ts">
  import './topBar.css';
  import Title from './Title.svelte';
  import Info from './Info.svelte';
</script>

<div id="topBar">
  <Title />
  <Info />
