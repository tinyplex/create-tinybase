  "client/src/App.svelte": "<script lang="ts">
  import {Provider} from 'tinybase/ui-svelte';
  import {Inspector} from 'tinybase/ui-svelte-inspector';
  import Game from './Game.svelte';
  import Loading from './Loading.svelte';
  import Store from './Store.svelte';

  let loading = $state(true);
</script>

<Provider>
  <Store onReady={() => (loading = false)} />
  {#if loading}
    <Loading />
  {:else}
    <Game />
    <Inspector />
  {/if}
</Provider>
",
  "client/src/Board.svelte": "<script lang="ts">
  import './board.css';
  import {getTable, getValues, getStore} from 'tinybase/ui-svelte';
  import Square from './Square.svelte';
  import {STORE_ID} from './store';
  import type {Store} from 'tinybase';

  const store = getStore(STORE_ID) as Store;

  const positions = Array.from({length: 9}, (_, i) => i.toString());

  const board = getTable('board', STORE_ID) as {
    readonly current: Record<string, {value?: string}>;
  };

  const gameState = getValues(STORE_ID) as {
    readonly current: {
      currentPlayer?: string;
      gameStatus?: string;
      winningLine?: string;
    };
  };

  const getSquare = (position: string) => {
    const gameStatus = gameState.current.gameStatus ?? 'playing';
    const winningLine = gameState.current.winningLine ?? '';
    const winningPositions = new Set(winningLine ? winningLine.split(',') : []);
    const value = board.current[position]?.value ?? '';

    return {
      value,
      disabled: gameStatus !== 'playing' || !!value,
      winning: winningPositions.has(position),
    };
  };

  const handleSquareClick = (position: string) => {
    const gameStatus = gameState.current.gameStatus ?? 'playing';
    const currentPlayer = gameState.current.currentPlayer ?? 'X';
    const value = board.current[position]?.value;

    if (gameStatus === 'playing' && !value && currentPlayer) {
      store.setCell('board', position, 'value', currentPlayer);
    }
  };
</script>

<div id="board">
  {#each positions as position (position)}
    {@const square = getSquare(position)}
    <Square
      value={square.value}
      disabled={square.disabled}
      winning={square.winning}
      handleClick={() => handleSquareClick(position)}
    />
  {/each}
</div>
",
  "client/src/Button.svelte": "<script lang="ts">
  import './button.css';
  import type {Snippet} from 'svelte';

  let {
    children,
    onclick = undefined,
    type = 'button',
    variant = 'default',
  }: {
    children?: Snippet;
    onclick?: () => void;
    type?: 'button' | 'submit' | 'reset';
    variant?: 'default' | 'primary';
  } = $props();
</script>

<button {type} class:primary={variant === 'primary'} {onclick}>
  {@render children?.()}
</button>
",
  "client/src/Game.svelte": "<script>
  import {onMount} from 'svelte';
  import Button from './Button.svelte';
  import {getStore} from 'tinybase/ui-svelte';
  import Board from './Board.svelte';
  import GameStatus from './GameStatus.svelte';
  import {STORE_ID} from './store';

  const store = getStore(STORE_ID);

  const WINNING_LINES = [
    ['0', '1', '2'],
    ['3', '4', '5'],
    ['6', '7', '8'],
    ['0', '3', '6'],
    ['1', '4', '7'],
    ['2', '5', '8'],
    ['0', '4', '8'],
    ['2', '4', '6'],
  ];

  const checkGameState = () => {
    const gameStatus = store.getValue('gameStatus');
    if (gameStatus !== 'playing') {
      return;
    }

    for (const line of WINNING_LINES) {
      const [a, b, c] = line;
      const cellA = store.getCell('board', a, 'value');
      const cellB = store.getCell('board', b, 'value');
      const cellC = store.getCell('board', c, 'value');

      if (cellA && cellA === cellB && cellA === cellC) {
        store.setValue('gameStatus', 'won');
        store.setValue('winner', cellA);
        store.setValue('winningLine', line.join(','));
        return;
      }
    }

    if (store.getRowCount('board') === 9) {
      store.setValue('gameStatus', 'draw');
      return;
    }

    const currentPlayer = store.getValue('currentPlayer');
    store.setValue('currentPlayer', currentPlayer === 'X' ? 'O' : 'X');
  };

  const resetGame = () => {
    store.delTable('board');
    store.setValues({
      currentPlayer: 'X',
      gameStatus: 'playing',
    });
  };

  onMount(() => {
    store.addTableListener('board', checkGameState, true);
  });
</script>

<GameStatus />
<Board />
<div style="text-align: center; margin-top: 2rem;">
  <Button variant="primary" onclick={resetGame}>New Game</Button>
</div>
",
  "client/src/GameStatus.svelte": "<script lang="ts">
  import './gameStatus.css';
  import {getValues} from 'tinybase/ui-svelte';
  import {STORE_ID} from './store';

  const status = getValues(STORE_ID) as {
    readonly current: {
      currentPlayer?: string;
      gameStatus?: string;
      winner?: string;
    };
  };
</script>

<div id="gameStatus">
  {#if status.current.gameStatus === 'playing'}
    Player <span class="player">{status.current.currentPlayer}</span>'s turn
  {:else if status.current.gameStatus === 'won'}
    Player <span class="winner">{status.current.winner}</span> wins!
  {:else if status.current.gameStatus === 'draw'}
    It's a draw!
  {/if}
</div>
",
