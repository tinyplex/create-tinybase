  "client/src/board.css": "#board {
  display: grid;
  grid-template-columns: repeat(3, 100px);
  grid-template-rows: repeat(3, 100px);
  gap: 1px;
  background: var(--border);
  border: 2px solid var(--border);
  border-radius: 0.5rem;
  overflow: hidden;
