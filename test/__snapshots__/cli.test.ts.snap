  right: 0.75rem;
  top: -0.375rem;
  width: 0.75rem;
  height: 0.75rem;
  background: var(--info-bg2);
  border-left: 1px solid var(--info-border);
  border-top: 1px solid var(--info-border);
  transform: rotate(45deg);
}
