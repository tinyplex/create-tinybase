  "client/src/info.css": "#info {
  --info-fg: var(--fg, oklch(85% 0.01 270));
  --info-fg2: var(--fg2, oklch(60% 0.01 270));
  --info-bg2: var(--bg2, oklch(25% 0.01 270));
