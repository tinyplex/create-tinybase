  let {
    children,
    onclick = undefined,
    type = 'button',
    variant = 'default',
  }: {
    children?: Snippet;
    onclick?: () => void;
    type?: 'button' | 'submit' | 'reset';
    variant?: 'default' | 'primary';
  } = $props();
</script>

<button {type} class:primary={variant === 'primary'} {onclick}>
  {@render children?.()}
</button>
