  "client/src/App.jsx": "import {App as TinyBaseApp} from './TinyBaseApp';
import {TopBar} from './TopBar';

export const App = () => (
  <>
    <TopBar />
    <div id="app">
      <TinyBaseApp />
    </div>
  </>
);
",
  "client/src/Button.jsx": "import './button.css';
import {ReactNode} from 'react';

export const Button = ({
  children,
  onClick,
  variant = 'default',
  type = 'button',
}) => (
  <button
    onClick={onClick}
    type={type}
    className={variant === 'primary' ? 'primary' : undefined}
  >
    {children}
  </button>
);
",
  "client/src/ChatStore.jsx": "import {
  useCreateMergeableStore,
  useProvideStore,
  useAddRowCallback,
  useRow,
  useSortedRowIds,
  useStore,
} from 'tinybase/ui-react';
import {STORE_ID, createChatStore} from './chatStoreData';
import {createSqliteWasmPersister} from 'tinybase/persisters/persister-sqlite-wasm';
import {useCreatePersister} from 'tinybase/ui-react';
import {getDb} from './sqlite';

export {STORE_ID};
export {useAddRowCallback, useRow, useSortedRowIds, useStore};

export const ChatStore = ({onReady}) => {
  const store = useCreateMergeableStore(() => createChatStore());

  useProvideStore(STORE_ID, store);

  useCreatePersister(
    store,
    async (store) => {
      const {sqlite3, db} = await getDb();
      return createSqliteWasmPersister(store, sqlite3, db, STORE_ID);
    },
    [],
    async (persister) => {
      await persister.load();
      await persister.startAutoSave();
      onReady?.();
    },
  );

  return null;
};
",
  "client/src/Info.jsx": "import './info.css';

export const Info = () => (
  <div id="info">
    <div id="infoTech">
      <img
        src="/js.svg"
        className="infoTechIcon"
        title="Written in JavaScript"
      />
      <img src="/react.svg" className="infoTechIcon" title="Built with React" />
      <img
        src="/sqlite.svg"
        className="infoTechIcon"
        title="Persists data to SQLite"
      />
    </div>
    <div id="infoIcon">
      i
      <div id="infoTooltip">
        {
          "A real-time chat application demonstrating TinyBase's reactive data management."
        }
      </div>
    </div>
  </div>
);
",
  "client/src/Input.jsx": "import './input.css';

export const Input = ({
  id,
  value,
  onChange,
  placeholder = '',
  autoFocus = false,
}) => (
  <input
    id={id}
    type="text"
    value={value}
    onChange={(e) => onChange(e.target.value)}
    placeholder={placeholder}
    autoFocus={autoFocus}
  />
);
",
  "client/src/Loading.jsx": "import './loading.css';

export const Loading = () => <div id="loading" />;
",
  "client/src/Message.jsx": "import {useRow, STORE_ID} from './ChatStore';
import './message.css';

export const Message = ({rowId}) => {
  const {username, text, timestamp} = useRow('messages', rowId, STORE_ID);

  return (
    <div className="message">
      <span className="username">{username}:</span>
      <span className="text">{text}</span>
      <span className="time">{new Date(timestamp).toLocaleTimeString()}</span>
    </div>
  );
};
",
  "client/src/MessageInput.jsx": "import {useState} from 'react';
import {useAddRowCallback, STORE_ID as CHAT_STORE_ID} from './ChatStore';
import {useValue, STORE_ID as SETTINGS_STORE_ID} from './SettingsStore';
import './messageInput.css';
import {Button} from './Button';
import {Input} from './Input';

export const MessageInput = () => {
  const [message, setMessage] = useState('');
  const username = useValue('username', SETTINGS_STORE_ID) || 'Anonymous';

  const handleSend = useAddRowCallback(
    'messages',
    () => ({
      username,
      text: message.trim(),
      timestamp: Date.now(),
    }),
    [message, username],
    CHAT_STORE_ID,
  );

  const onSubmit = (e) => {
    e.preventDefault();
    if (message.trim()) {
      handleSend();
      setMessage('');
    }
  };

  return (
    <form onSubmit={onSubmit} id="messageInput">
      <Input
        value={message}
        onChange={setMessage}
        placeholder="Type a message..."
        autoFocus
      />
      <Button type="submit" variant="primary">
        Send
      </Button>
    </form>
  );
};
",
  "client/src/Messages.jsx": "import {useSortedRowIds, STORE_ID} from './ChatStore';
import './messages.css';
import {Message} from './Message';

export const Messages = () => {
  const sortedIds = useSortedRowIds(
    'messages',
    'timestamp',
    false,
    0,
    undefined,
    STORE_ID,
  );

  return (
    <div id="messages">
      {sortedIds.map((id) => (
        <Message key={id} rowId={id} />
      ))}
    </div>
  );
};
",
  "client/src/SettingsStore.jsx": "import {
  useCreateStore,
  useProvideStore,
  useValue,
  useValueState,
} from 'tinybase/ui-react';
import {
  DEFAULT_VALUES,
  STORE_ID,
  createSettingsStore,
} from './settingsStoreData';
import {createSqliteWasmPersister} from 'tinybase/persisters/persister-sqlite-wasm';
import {useCreatePersister} from 'tinybase/ui-react';
import {getDb} from './sqlite';

export {STORE_ID};
export {useValue, useValueState};

export const SettingsStore = ({onReady}) => {
  const store = useCreateStore(() => createSettingsStore());

  useProvideStore(STORE_ID, store);

  useCreatePersister(
    store,
    async (store) => {
      const {sqlite3, db} = await getDb();
      return createSqliteWasmPersister(store, sqlite3, db, STORE_ID);
    },
    [],
    async (persister) => {
      await persister.load([{}, DEFAULT_VALUES]);
      await persister.startAutoSave();
      onReady?.();
    },
  );

  return null;
};
",
  "client/src/TinyBaseApp.jsx": "import {StrictMode, useState} from 'react';
import {Loading} from './Loading';
import {Provider} from 'tinybase/ui-react';
import {Inspector} from 'tinybase/ui-react-inspector';
import {SettingsStore} from './SettingsStore';
import {ChatStore} from './ChatStore';
import {UsernameInput} from './UsernameInput';
import {Messages} from './Messages';
import {MessageInput} from './MessageInput';

export const App = () => {
  const [settingsReady, setSettingsReady] = useState(false);
  const [chatReady, setChatReady] = useState(false);
  const loading = !settingsReady || !chatReady;

  return (
    <StrictMode>
      <Provider>
        <SettingsStore onReady={() => setSettingsReady(true)} />
        <ChatStore onReady={() => setChatReady(true)} />
        {loading ? (
          <Loading />
        ) : (
          <>
            <UsernameInput />
            <Messages />
            <MessageInput />
            <Inspector />
          </>
        )}
      </Provider>
    </StrictMode>
  );
};
",
  "client/src/Title.jsx": "import './title.css';

export const Title = () => (
  <h1 id="topBarTitle">
    <img src="/favicon.svg" id="topBarLogo" alt="TinyBase" />
    TinyBase Chat
  </h1>
);
",
  "client/src/TopBar.jsx": "import './topBar.css';
import {Info} from './Info';
import {Title} from './Title';

export const TopBar = () => (
  <div id="topBar">
    <Title />
    <Info />
  </div>
);
",
  "client/src/UsernameInput.jsx": "import {useValueState, STORE_ID} from './SettingsStore';
import './usernameInput.css';
import {Input} from './Input';

export const UsernameInput = () => {
  const [username, setUsername] = useValueState('username', STORE_ID);

  return (
    <div id="usernameInput">
      <label htmlFor="usernameInputField">Your name:</label>
      <Input
        id="usernameInputField"
        value={String(username ?? '')}
        onChange={setUsername}
        placeholder="Enter your name"
      />
    </div>
  );
};
",
  "client/src/button.css": "button {
  padding: 0.5rem 1rem;
  border: 1px solid #666;
  border-radius: 0.25rem;
  background: #222;
  color: #fff;
  font-family: inherit;
  font-weight: 800;
  cursor: pointer;
  margin: 0.5rem;
}

button:hover {
  border-color: #d81b60;
}

button.primary {
  background: #d81b60;
  border: none;
  padding: 0.75rem 1.5rem;
}

button.primary:hover {
  background: #c2185b;
}
",
  "client/src/chatStoreData.js": "import {createMergeableStore} from 'tinybase';
import {getDefaultContent} from './utils';

export const STORE_ID = 'chat';

export const createChatStore = () =>
  createMergeableStore().setDefaultContent(getDefaultContent());
",
  "client/src/index.jsx": "import ReactDOM from 'react-dom/client';
import {App} from './App';

addEventListener('load', () => {
  ReactDOM.createRoot(document.getElementById('appContainer')).render(<App />);
});
",
  "client/src/info.css": "#info {
  --info-fg: var(--fg, oklch(85% 0.01 270));
  --info-fg2: var(--fg2, oklch(60% 0.01 270));
  --info-bg2: var(--bg2, oklch(25% 0.01 270));
  --info-border: var(--border, oklch(30% 0.01 270));
  --info-accent: var(--accent, #d81b60);
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

#infoTech {
  display: flex;
  align-items: center;
  gap: 0.375rem;
}

.infoTechIcon {
  width: 1.25rem;
  height: 1.25rem;
  display: block;
  flex-shrink: 0;
}

#infoIcon {
  width: 1.25rem;
  height: 1.25rem;
  border: 2px solid var(--info-fg2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 800;
  color: var(--info-fg2);
  cursor: help;
  transition: all 0.2s;
  user-select: none;
}

#infoIcon:hover {
  border-color: var(--info-accent);
  color: var(--info-accent);
}

#infoIcon:hover #infoTooltip {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

#infoTooltip {
  position: absolute;
  right: 0;
  top: calc(100% + 0.5rem);
  background: var(--info-bg2);
  border: 1px solid var(--info-border);
  border-radius: 0.375rem;
  padding: 0.75rem 1rem;
  font-size: 0.85rem;
  font-weight: 400;
  width: 20rem;
