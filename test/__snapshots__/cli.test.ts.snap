  "client/src/button.ts": "import './button.css';

export const createButton = (
  text: string,
  onClick: (() => void) | null,
  variant: 'default' | 'primary' = 'default',
  type: 'button' | 'submit' = 'button',
): HTMLButtonElement => {
  const button = document.createElement('button');
  button.textContent = text;
  button.type = type;
  if (variant === 'primary') {
    button.className = 'primary';
  }
  if (onClick) {
    button.addEventListener('click', onClick);
  }
  return button;
};
",
  "client/src/chatStore.ts": "import {createMergeableStore} from 'tinybase';
import {getDefaultContent} from './utils';
import {createLocalPersister} from 'tinybase/persisters/persister-browser';

export const STORE_ID = 'chat';

export type MessageRow = {username: string; text: string; timestamp: number};

export const createChatStore = () =>
  createMergeableStore().setDefaultContent(getDefaultContent());

export const chatStore = createChatStore();

let resolveChatReady: () => void;
export const chatStoreReady = new Promise<void>((resolve) => {
  resolveChatReady = resolve;
});

const chatPersister = createLocalPersister(chatStore, STORE_ID);
chatPersister.load().then(() => {
  chatPersister.startAutoSave();
  resolveChatReady();
});

export type ChatStore = typeof chatStore;
",
  "client/src/index.ts": "import {createTopBar} from './topBar';
import {app} from './app';

addEventListener('load', () => {
  document.getElementById('topBarMount')?.replaceWith(createTopBar());
  app();
});
