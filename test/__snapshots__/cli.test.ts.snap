  "client/src/board.css": "#board {
  display: grid;
  grid-template-columns: repeat(3, 100px);
  grid-template-rows: repeat(3, 100px);
  gap: 1px;
  background: var(--border);
  border: 2px solid var(--border);
  border-radius: 0.5rem;
  overflow: hidden;
  margin: 0 auto 2rem;
  width: fit-content;
  padding: 1px;
}
",
  "client/src/button.css": "button {
  padding: 0.5rem 1rem;
  border: 1px solid #666;
  border-radius: 0.25rem;
  background: #222;
  color: #fff;
  font-family: inherit;
  font-weight: 800;
  cursor: pointer;
  margin: 0.5rem;
}

button:hover {
  border-color: #d81b60;
}

button.primary {
  background: #d81b60;
  border: none;
  padding: 0.75rem 1.5rem;
}

button.primary:hover {
  background: #c2185b;
}
",
  "client/src/config.ts": "export const SERVER = 'wss://vite.tinybase.org';
",
  "client/src/gameStatus.css": "#gameStatus {
  text-align: center;
  font-size: 1.5rem;
  font-weight: 800;
  margin: 2rem 0 1rem;
  color: var(--accent);
}

#gameStatus .winner {
  color: var(--accent);
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}
",
  "client/src/index.ts": "import {getUniqueId} from 'tinybase';
import {mount} from 'svelte';
import App from './App.svelte';
import TopBar from './TopBar.svelte';

if (location.pathname === '/') {
  location.assign('/' + getUniqueId());
}

addEventListener('load', () => {
  mount(TopBar, {
    target: document.getElementById('topBarMount')!,
  });
  mount(App, {
    target: document.getElementById('app')!,
  });
});
",
  "client/src/info.css": "#info {
  --info-fg: var(--fg, oklch(85% 0.01 270));
  --info-fg2: var(--fg2, oklch(60% 0.01 270));
  --info-bg2: var(--bg2, oklch(25% 0.01 270));
  --info-border: var(--border, oklch(30% 0.01 270));
  --info-accent: var(--accent, #d81b60);
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

#infoTech {
  display: flex;
  align-items: center;
  gap: 0.375rem;
}

.infoTechIcon {
  width: 1.25rem;
  height: 1.25rem;
  display: block;
  flex-shrink: 0;
}

#infoIcon {
  width: 1.25rem;
  height: 1.25rem;
  border: 2px solid var(--info-fg2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 800;
  color: var(--info-fg2);
  cursor: help;
  transition: all 0.2s;
  user-select: none;
}

#infoIcon:hover {
  border-color: var(--info-accent);
  color: var(--info-accent);
}

#infoIcon:hover #infoTooltip {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

#infoTooltip {
  position: absolute;
  right: 0;
  top: calc(100% + 0.5rem);
  background: var(--info-bg2);
  border: 1px solid var(--info-border);
  border-radius: 0.375rem;
  padding: 0.75rem 1rem;
  font-size: 0.85rem;
  font-weight: 400;
  width: 20rem;
  white-space: normal;
  color: var(--info-fg);
  line-height: 1.5;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-0.25rem);
  transition: all 0.2s;
  pointer-events: none;
  box-shadow: 0 1px 2px 0 #0007;
  z-index: 1;
}

#infoTooltip a {
  color: var(--info-fg);
  text-decoration: underline;
}

#infoTooltip::before {
  content: '';
  position: absolute;
  right: 0.75rem;
  top: -0.375rem;
  width: 0.75rem;
  height: 0.75rem;
  background: var(--info-bg2);
  border-left: 1px solid var(--info-border);
  border-top: 1px solid var(--info-border);
  transform: rotate(45deg);
}
",
  "client/src/loading.css": "#loading {
  animation: spin 1s infinite linear;
  height: 2rem;
  margin: 40vh auto;
  width: 2rem;
}

#loading::before {
  content: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" height="2rem" viewBox="0 0 100 100"><path d="M50 10A40 40 0 1 1 10 50" stroke="%23d81b60" fill="none" stroke-width="4" /></svg>');
}

@keyframes spin {
  from {
    transform: rotate(0);
  }
  to {
    transform: rotate(360deg);
  }
}
",
  "client/src/square.css": ".square {
  width: 100px;
  height: 100px;
  background: var(--bg2);
  border: none;
  font-size: 2.5rem;
  font-weight: 800;
  color: var(--fg);
  cursor: pointer;
  transition: all 0.15s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.square:hover:not(.square.disabled) {
  background: var(--bg);
  outline: 2px solid var(--accent);
  outline-offset: -2px;
  z-index: 1;
  position: relative;
}

.square:disabled {
  cursor: not-allowed;
}

.square.disabled {
  cursor: not-allowed;
  opacity: 0.7;
}

.square.winning {
  background: var(--accent);
  color: var(--bg);
}
",
  "client/src/store.ts": "import {createMergeableStore} from 'tinybase';

export const STORE_ID = 'game';

export const createGameStore = () =>
  createMergeableStore().setDefaultContent([
    {},
    {
      currentPlayer: 'X',
      gameStatus: 'playing',
    },
  ]);
",
