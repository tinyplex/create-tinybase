  "client/src/BrushSize.jsx": "import {useValueState, STORE_ID} from './SettingsStore';
import './brushSize.css';

export const BrushSize = () => {
  const [size, setSize] = useValueState('brushSize', STORE_ID);

  const handleChange = (e) => {
    setSize(parseInt(e.target.value));
  };

  return (
    <div id="brushSize">
      <label htmlFor="brushSizeSlider">Size:</label>
      <input
        id="brushSizeSlider"
        type="range"
        min="1"
        max="50"
        value={size ?? 5}
        onChange={handleChange}
      />
      <span id="brushSizeValue">{size ?? 5}</span>
    </div>
  );
};
