  "client/src/info.ts": "import './info.css';

export const createInfo = (): HTMLDivElement => {
  const container = document.createElement('div');
  container.id = 'info';

  const tech = document.createElement('div');
  tech.id = 'infoTech';
  container.appendChild(tech);

  addIcon(tech, '/ts.svg', 'Written in TypeScript');

  const infoIcon = document.createElement('div');
  infoIcon.id = 'infoIcon';
  infoIcon.textContent = 'i';

  const tooltip = document.createElement('div');
  tooltip.id = 'infoTooltip';
  tooltip.textContent = \`A tic-tac-toe game demonstrating turn-based logic and computed game state using TinyBase.\`;

  infoIcon.appendChild(tooltip);
  container.appendChild(infoIcon);

  return container;
};

const addIcon = (
  container: HTMLElement,
  src: string,
  title: string,
): HTMLImageElement => {
  const icon = document.createElement('img');
  icon.src = src;
  icon.className = 'infoTechIcon';
  icon.title = title;
  container.appendChild(icon);
  return icon;
};
",
