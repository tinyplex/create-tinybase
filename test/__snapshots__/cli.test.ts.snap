  "client/src/Canvas.svelte": "<script lang="ts">
  import './canvas.css';
  import {onMount} from 'svelte';
  import {getHlcFunctions} from 'tinybase';
  import {getStore} from 'tinybase/ui-svelte';
  import {STORE_ID as CANVAS_STORE_ID} from './canvasStore';
  import type {Store} from 'tinybase';
  import type {StrokeRow} from './canvasStore';
  import {STORE_ID as SETTINGS_STORE_ID} from './settingsStore';

  const canvasStore = getStore(CANVAS_STORE_ID) as Store;
  const settingsStore = getStore(SETTINGS_STORE_ID) as Store;

  const [getNextHlc] = getHlcFunctions();

  let canvas: HTMLCanvasElement | undefined;
  let isDrawing = false;
  let currentStrokeId: string | null = null;

  const getPoint = (event: MouseEvent | TouchEvent) => {
    if (!canvas) {
      return null;
    }

    const rect = canvas.getBoundingClientRect();
    const clientX =
      'touches' in event ? event.touches[0]?.clientX : event.clientX;
    const clientY =
      'touches' in event ? event.touches[0]?.clientY : event.clientY;

    if (clientX == null || clientY == null) {
      return null;
    }

    return {
      x: clientX - rect.left,
      y: clientY - rect.top,
    };
  };

  const startStroke = (event: MouseEvent | TouchEvent) => {
    isDrawing = true;
    currentStrokeId = getNextHlc();

    const point = getPoint(event);
    if (!point || !currentStrokeId) {
      return;
    }

    const brushColor =
      (settingsStore.getValue('brushColor') as string | undefined) ?? '#d81b60';
    const brushSize =
      (settingsStore.getValue('brushSize') as number | undefined) ?? 5;

    canvasStore.setRow('strokes', currentStrokeId, {
      color: brushColor,
      size: brushSize,
      points: JSON.stringify([point.x, point.y]),
    });
  };

  const extendStroke = (event: MouseEvent | TouchEvent) => {
    if (!isDrawing || !currentStrokeId) {
      return;
    }

    const point = getPoint(event);
    if (!point) {
      return;
    }

    const pointsArray = JSON.parse(
      (canvasStore.getCell('strokes', currentStrokeId, 'points') as
        | string
        | undefined) ?? '[]',
    ) as number[];
    pointsArray.push(point.x, point.y);
    canvasStore.setCell(
      'strokes',
      currentStrokeId,
      'points',
      JSON.stringify(pointsArray),
    );
  };

  const endStroke = () => {
    isDrawing = false;
    currentStrokeId = null;
  };

  const handleTouchStart = (event: TouchEvent) => {
    event.preventDefault();
    startStroke(event);
  };

  const handleTouchMove = (event: TouchEvent) => {
    event.preventDefault();
    extendStroke(event);
  };

  onMount(() => {
    const draw = () => {
      if (!canvas) {
        return;
      }

      const ctx = canvas.getContext('2d');
      if (!ctx) {
        return;
      }

      ctx.fillStyle = '#111';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      canvasStore.getSortedRowIds('strokes').forEach((id) => {
        const stroke = canvasStore.getRow('strokes', id) as
          | StrokeRow
          | undefined;
        if (!stroke?.points) {
          return;
        }

        const pointsArray = JSON.parse(stroke.points) as number[];
        if (pointsArray.length < 2) {
          return;
        }

        ctx.strokeStyle = stroke.color;
        ctx.lineWidth = stroke.size * 2;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.beginPath();
        ctx.moveTo(pointsArray[0], pointsArray[1]);
        for (let i = 2; i < pointsArray.length; i += 2) {
          ctx.lineTo(pointsArray[i], pointsArray[i + 1]);
        }
        ctx.stroke();
      });
    };

    canvasStore.addTablesListener(draw);
    draw();
  });
</script>

<canvas
  bind:this={canvas}
  id="drawingCanvas"
  width="600"
  height="400"
  onmousedown={startStroke}
  onmousemove={extendStroke}
  onmouseup={endStroke}
  onmouseleave={endStroke}
  ontouchstart={handleTouchStart}
  ontouchmove={handleTouchMove}
  ontouchend={endStroke}
></canvas>
",
  "client/src/CanvasStore.svelte": "<script lang="ts">
  import {provideStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {createLocalPersister} from 'tinybase/persisters/persister-browser';
  import {STORE_ID, createCanvasStore} from './canvasStore';

  let {onReady}: {onReady?: () => void} = $props();

  const store = createCanvasStore();

  provideStore(STORE_ID, store);

  onMount(async () => {
    const persister = createLocalPersister(store, STORE_ID);
    await persister.load();
    await persister.startAutoSave();
    onReady?.();
  });
</script>
",
  "client/src/ColorPicker.svelte": "<script lang="ts">
  import './colorPicker.css';
  import {getValue} from 'tinybase/ui-svelte';
  import {STORE_ID} from './settingsStore';

  const colors = [
    '#d81b60',
    '#1976d2',
    '#388e3c',
    '#f57c00',
    '#7b1fa2',
    '#fff',
  ];
  const currentColor = getValue('brushColor', STORE_ID) as {
    current: string | undefined;
  };

  const setColor = (color: string) => {
    currentColor.current = color;
  };
</script>

<div id="colorPicker">
  {#each colors as color (color)}
    <button
      class="colorBtn"
      class:active={currentColor.current === color}
      style={\`background: \${color}\`}
      onclick={() => setColor(color)}
      aria-label={\`Select \${color} brush\`}
      title={color}
    ></button>
  {/each}
</div>
",
  "client/src/DrawingControls.svelte": "<script>
  import './drawingControls.css';
  import Button from './Button.svelte';
  import {getStore} from 'tinybase/ui-svelte';
  import BrushSize from './BrushSize.svelte';
  import ColorPicker from './ColorPicker.svelte';
  import {STORE_ID} from './canvasStore';

  const canvasStore = getStore(STORE_ID);

  const clearStrokes = () => {
    canvasStore.delTable('strokes');
  };
</script>

<div id="drawingControls">
  <ColorPicker />
  <BrushSize />
  <Button variant="primary" onclick={clearStrokes}>Clear</Button>
</div>
",
