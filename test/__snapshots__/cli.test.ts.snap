  "client/src/App.svelte": "<script>
  import {Provider} from 'tinybase/ui-svelte';
  import {Inspector} from 'tinybase/ui-svelte-inspector';
  import ChatStore from './ChatStore.svelte';
  import Loading from './Loading.svelte';
  import MessageInput from './MessageInput.svelte';
  import Messages from './Messages.svelte';
  import SettingsStore from './SettingsStore.svelte';
  import UsernameInput from './UsernameInput.svelte';

  let settingsReady = $state(false);
  let chatReady = $state(false);
  const loading = $derived(!settingsReady || !chatReady);
</script>

<Provider>
  <SettingsStore onReady={() => (settingsReady = true)} />
  <ChatStore onReady={() => (chatReady = true)} />
  {#if loading}
    <Loading />
  {:else}
    <UsernameInput />
    <Messages />
    <MessageInput />
    <Inspector />
  {/if}
</Provider>
",
  "client/src/Button.svelte": "<script>
  import './button.css';

  let {
    children,
    onclick = undefined,
    type = 'button',
    variant = 'default',
  } = $props();
</script>

<button {type} class:primary={variant === 'primary'} {onclick}>
  {@render children?.()}
</button>
",
  "client/src/ChatStore.svelte": "<script>
  import {provideStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {createLocalPersister} from 'tinybase/persisters/persister-browser';
  import {STORE_ID, createChatStore} from './chatStore';

  let {onReady} = $props();

  const store = createChatStore();

  provideStore(STORE_ID, store);

  onMount(async () => {
    const persister = createLocalPersister(store, STORE_ID);
    await persister.load();
    await persister.startAutoSave();
    onReady?.();
  });
</script>
",
  "client/src/Info.svelte": "<script>
  import './info.css';
</script>

<div id="info">
  <div id="infoTech">
    <img src="/js.svg" class="infoTechIcon" title="Written in JavaScript" />
    <img src="/svelte.svg" class="infoTechIcon" title="Built with Svelte" />
  </div>
  <div id="infoIcon">
    i
    <div id="infoTooltip">
      A real-time chat application demonstrating TinyBase's reactive data
      management.
    </div>
  </div>
</div>
",
  "client/src/Input.svelte": "<script>
  import './input.css';
  import {onMount} from 'svelte';

  let {
    id = undefined,
    value = '',
    onChange = undefined,
    placeholder = '',
    autoFocus = false,
  } = $props();

  let input;

  const handleInput = (event) => {
    const input = event.currentTarget;
    onChange?.(input.value);
  };

  onMount(() => {
    if (autoFocus) {
      input?.focus();
    }
  });
</script>

<input
  bind:this={input}
  {id}
  type="text"
  {value}
  oninput={handleInput}
  {placeholder}
/>
",
  "client/src/Loading.svelte": "<script>
  import './loading.css';
</script>

<div id="loading"></div>
",
  "client/src/Message.svelte": "<script>
  import './message.css';
  import {getRow} from 'tinybase/ui-svelte';
  import {STORE_ID} from './chatStore';

  let {rowId} = $props();

  const message = getRow('messages', () => rowId, STORE_ID);

  const getTime = (timestamp) => new Date(timestamp).toLocaleTimeString();
</script>

<div class="message">
  <span class="username">{message.current.username}:</span>
  <span class="text">{message.current.text}</span>
  <span class="time">{getTime(message.current.timestamp)}</span>
</div>
",
  "client/src/MessageInput.svelte": "<script>
  import './input.css';
  import './messageInput.css';
  import Button from './Button.svelte';
  import {getValue, getStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {STORE_ID as CHAT_STORE_ID} from './chatStore';
  import {STORE_ID as SETTINGS_STORE_ID} from './settingsStore';

  let message = $state('');
  let input;

  const chatStore = getStore(CHAT_STORE_ID);

  const username = getValue('username', SETTINGS_STORE_ID);

  const sendMessage = () => {
    const text = message.trim();
    if (!text) {
      return;
    }

    chatStore.addRow('messages', {
      username: username.current || 'Anonymous',
      text,
      timestamp: Date.now(),
    });

    message = '';
    input?.focus();
  };

  const handleSubmit = (event) => {
    event.preventDefault();
    sendMessage();
  };

  onMount(() => {
    input?.focus();
  });
</script>

<form id="messageInput" onsubmit={handleSubmit}>
  <input
    bind:this={input}
    bind:value={message}
    type="text"
    placeholder="Type a message..."
  />
  <Button variant="primary" type="submit">Send</Button>
</form>
",
  "client/src/Messages.svelte": "<script>
  import './messages.css';
  import {getSortedRowIds} from 'tinybase/ui-svelte';
  import Message from './Message.svelte';
  import {STORE_ID} from './chatStore';

  const messageIds = getSortedRowIds(
    'messages',
    'timestamp',
    false,
    0,
    undefined,
    STORE_ID,
  );
</script>

<div id="messages">
  {#each messageIds.current as rowId (rowId)}
    <Message {rowId} />
  {/each}
</div>
",
  "client/src/SettingsStore.svelte": "<script>
  import {provideStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {createLocalPersister} from 'tinybase/persisters/persister-browser';
  import {DEFAULT_VALUES, STORE_ID, createSettingsStore} from './settingsStore';

  let {onReady} = $props();

  const store = createSettingsStore();

  provideStore(STORE_ID, store);

  onMount(async () => {
    const persister = createLocalPersister(store, STORE_ID);
    await persister.load([{}, DEFAULT_VALUES]);
    await persister.startAutoSave();
    onReady?.();
  });
</script>
",
