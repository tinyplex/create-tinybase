  import {Provider} from 'tinybase/ui-svelte';
  import {Inspector} from 'tinybase/ui-svelte-inspector';
  import Canvas from './Canvas.svelte';
  import CanvasStore from './CanvasStore.svelte';
  import DrawingControls from './DrawingControls.svelte';
  import Loading from './Loading.svelte';
  import SettingsStore from './SettingsStore.svelte';

  let settingsReady = $state(false);
  let canvasReady = $state(false);
  const loading = $derived(!settingsReady || !canvasReady);
</script>

<Provider>
  <SettingsStore onReady={() => (settingsReady = true)} />
  <CanvasStore onReady={() => (canvasReady = true)} />
  {#if loading}
    <Loading />
  {:else}
    <DrawingControls />
    <Canvas />
    <Inspector />
  {/if}
</Provider>
