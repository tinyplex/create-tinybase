let pgLitePromise: Promise<PGlite> | null = null;

export const getPgLite = async (): Promise<PGlite> => {
  if (!pgLitePromise) {
    pgLitePromise = PGlite.create('idb://local');
  }
  return await pgLitePromise;
};
