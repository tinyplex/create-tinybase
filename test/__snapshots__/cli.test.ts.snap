  "client/src/utils.ts": "const NAMES = [
  'Carol',
  'Charlie',
  'Casey',
  'Cameron',
  'Chris',
  'Dana',
  'Dakota',
  'Drew',
  'Devon',
  'Dylan',
];

export const getRandomName = (): string =>
  NAMES[Math.floor(Math.random() * NAMES.length)];

export const getDefaultContent = (): [any, any] => [
  {
    messages: {
      '1': {username: 'Alice', text: 'Hello!', timestamp: 1704067200000},
      '2': {username: 'Bob', text: 'Hi there!', timestamp: 1704067230000},
    },
  },
  {},
];
",
  "client/src/vite-env.d.ts": "declare module '*.css' {
  const content: string;
  export default content;
}
