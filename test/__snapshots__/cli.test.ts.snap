  "client/src/App.svelte": "<script lang="ts">
  import {Provider} from 'tinybase/ui-svelte';
  import {Inspector} from 'tinybase/ui-svelte-inspector';
  import Loading from './Loading.svelte';
  import Store from './Store.svelte';
  import TodoInput from './TodoInput.svelte';
  import TodoList from './TodoList.svelte';

  let loading = $state(true);
</script>

<Provider>
  <Store onReady={() => (loading = false)} />
  {#if loading}
    <Loading />
  {:else}
    <TodoInput />
    <TodoList />
    <Inspector />
  {/if}
</Provider>
",
  "client/src/Button.svelte": "<script lang="ts">
  import './button.css';
  import type {Snippet} from 'svelte';

  let {
    children,
    onclick = undefined,
    type = 'button',
    variant = 'default',
  }: {
    children?: Snippet;
    onclick?: () => void;
    type?: 'button' | 'submit' | 'reset';
    variant?: 'default' | 'primary';
  } = $props();
</script>

<button {type} class:primary={variant === 'primary'} {onclick}>
  {@render children?.()}
</button>
",
  "client/src/Info.svelte": "<script lang="ts">
  import './info.css';
</script>

<div id="info">
  <div id="infoTech">
    <img src="/ts.svg" class="infoTechIcon" title="Written in TypeScript" />
    <img src="/svelte.svg" class="infoTechIcon" title="Built with Svelte" />
    <img
      src="/sqlite.svg"
      class="infoTechIcon"
      title="Persists data to SQLite"
    />
  </div>
  <div id="infoIcon">
    i
    <div id="infoTooltip">
      A simple todo list application demonstrating TinyBase's reactive data
      management with CRUD operations.
    </div>
  </div>
</div>
",
  "client/src/Loading.svelte": "<script>
  import './loading.css';
</script>

<div id="loading"></div>
",
  "client/src/Store.svelte": "<script lang="ts">
  import {provideStore} from 'tinybase/ui-svelte';
  import {onMount} from 'svelte';
  import {createSqliteWasmPersister} from 'tinybase/persisters/persister-sqlite-wasm';
  import {getDb} from './sqlite';
  import {STORE_ID, createTodosStore} from './store';

  let {onReady}: {onReady?: () => void} = $props();

  const store = createTodosStore();

  provideStore(STORE_ID, store);

  onMount(async () => {
    const {sqlite3, db} = await getDb();
    const persister = createSqliteWasmPersister(store, sqlite3, db, STORE_ID);
    await persister.load();
    await persister.startAutoSave();
    onReady?.();
  });
</script>
",
  "client/src/Title.svelte": "<script lang="ts">
  import './title.css';
</script>

<h1 id="topBarTitle">
  <img src="/favicon.svg" id="topBarLogo" alt="TinyBase" />
  TinyBase Todos
</h1>
",
  "client/src/TodoInput.svelte": "<script lang="ts">
  import './input.css';
  import './todoInput.css';
  import Button from './Button.svelte';
  import {onMount} from 'svelte';
  import {getStore} from 'tinybase/ui-svelte';
  import {STORE_ID} from './store';
  import type {Store} from 'tinybase';

  const store = getStore(STORE_ID) as Store;

  let text = $state('');
  let input: HTMLInputElement | undefined;

  const addTodo = () => {
    const trimmedText = text.trim();
    if (trimmedText) {
      store.addRow('todos', {text: trimmedText, completed: false});
      text = '';
      input?.focus();
    }
  };

  const handleSubmit = (event: SubmitEvent) => {
    event.preventDefault();
    addTodo();
  };

  onMount(() => {
    input?.focus();
  });
</script>

<form id="todoInput" onsubmit={handleSubmit}>
  <input
    bind:this={input}
    bind:value={text}
    type="text"
    placeholder="What needs to be done?"
  />
  <Button variant="primary" type="submit">Add</Button>
</form>
",
  "client/src/TodoItem.svelte": "<script lang="ts">
  import './button.css';
  import './todoItem.css';
  import {getRow, getStore} from 'tinybase/ui-svelte';
  import {STORE_ID} from './store';
  import type {Store} from 'tinybase';
  import type {TodoRow} from './store';

  const store = getStore(STORE_ID) as Store;

  let {rowId}: {rowId: string} = $props();

  const todo = getRow('todos', () => rowId, STORE_ID) as {
    readonly current: TodoRow;
  };

  const toggleTodo = (event: Event) => {
    const input = event.currentTarget as HTMLInputElement;
    store.setPartialRow('todos', rowId, {completed: input.checked});
  };

  const deleteTodo = () => {
    store.delRow('todos', rowId);
  };
</script>

<div class="todoItem" class:completed={todo.current.completed}>
  <input
    id={\`todo-\${rowId}\`}
    type="checkbox"
    checked={todo.current.completed}
    onchange={toggleTodo}
  />
  <label for={\`todo-\${rowId}\`}>{todo.current.text}</label>
  <button onclick={deleteTodo}>Delete</button>
</div>
",
  "client/src/TodoList.svelte": "<script lang="ts">
  import './todoList.css';
  import {getSortedRowIds} from 'tinybase/ui-svelte';
  import TodoItem from './TodoItem.svelte';
  import {STORE_ID} from './store';

  const todoIds = getSortedRowIds(
    'todos',
    undefined,
    false,
    0,
    undefined,
    STORE_ID,
  );
</script>

<div id="todoList">
  {#each todoIds.current as rowId (rowId)}
