      <img src="/react.svg" className="infoTechIcon" title="Built with React" />
      <img
        src="/sync.svg"
        className="infoTechIcon"
        title="Data synchronization enabled"
      />
    </div>
    <div id="infoIcon">
      i
      <div id="infoTooltip">
        {
          "A real-time chat application demonstrating TinyBase's reactive data management."
        }
      </div>
    </div>
  </div>
);
